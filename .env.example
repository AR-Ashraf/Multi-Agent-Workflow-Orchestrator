# ==========================================================================
# Multi-Agent Workflow Orchestrator — example environment file
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# All keys are read SERVER-SIDE ONLY (FastAPI / orchestrator). The Next.js
# frontend must never receive provider API keys.
# ==========================================================================

# ----- LLM (Claude API) ---------------------------------------------------
ANTHROPIC_API_KEY=

# ----- Tools: web search + page fetch -------------------------------------
TAVILY_API_KEY=
FIRECRAWL_API_KEY=

# ----- Datastores ---------------------------------------------------------
# PostgreSQL: saved runs, logs, artifacts, shareable links
DATABASE_URL=
# Redis: run state, event pub/sub, rate limiting, caching
REDIS_URL=

# ==========================================================================
# Optional / later — documented stack components. Uncomment when wired up.
# (Placeholders only; not required for the initial scaffold.)
# ==========================================================================

# ----- Observability: Langfuse (self-hosted) ------------------------------
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=

# ----- Alternative web search provider ------------------------------------
# BRAVE_API_KEY=

# ----- Bot gate (Turnstile / hCaptcha) ------------------------------------
# TURNSTILE_SECRET_KEY=
# TURNSTILE_SITE_KEY=

# ----- Cost & safety knobs (see CLAUDE.md) --------------------------------
# DAILY_LLM_SPEND_CAP_USD=
# PER_RUN_TOKEN_CEILING=
# PER_RUN_STEP_CEILING=
# RATE_LIMIT_PER_IP_PER_HOUR=

# ==========================================================================
# Frontend (Next.js) — PUBLIC, client-side vars (NEXT_PUBLIC_*).
# These ARE shipped to the browser. Only public measurement IDs / URLs here —
# NEVER a provider API key (§8, §11).
# ==========================================================================
# Base URL of the FastAPI gateway the browser calls (REST + SSE). Unset → the
# UI runs the cached client-side demo only (no backend).
# NEXT_PUBLIC_API_BASE=https://agents.devs-core.com
# GA4 / GTM measurement IDs — cross-domain devs-core.com ↔ agents.devs-core.com.
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
# Booking link for the "Book a build call" CTA (falls back to the #book anchor).
# NEXT_PUBLIC_BOOK_URL=https://cal.com/devs-core/build-call
