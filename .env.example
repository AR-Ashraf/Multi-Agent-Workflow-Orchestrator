# ==========================================================================
# Multi-Agent Workflow Orchestrator — example environment file
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# All keys are read SERVER-SIDE ONLY (FastAPI / orchestrator). The Next.js
# frontend must never receive provider API keys.
# ==========================================================================

# ----- LLM (Claude API) ---------------------------------------------------
ANTHROPIC_API_KEY=

# ----- Tools: web search + page fetch -------------------------------------
TAVILY_API_KEY=
FIRECRAWL_API_KEY=

# ----- Datastores ---------------------------------------------------------
# PostgreSQL: saved runs, logs, artifacts, shareable links
DATABASE_URL=
# Redis: run state, event pub/sub, rate limiting, caching
REDIS_URL=

# ==========================================================================
# Optional / later — documented stack components. Uncomment when wired up.
# (Placeholders only; not required for the initial scaffold.)
# ==========================================================================

# ----- Observability: Langfuse (self-hosted) ------------------------------
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=

# ----- Alternative web search provider ------------------------------------
# BRAVE_API_KEY=

# ----- Bot gate (Turnstile / hCaptcha) ------------------------------------
# TURNSTILE_SECRET_KEY=
# TURNSTILE_SITE_KEY=

# ----- Cost & safety knobs (see CLAUDE.md) --------------------------------
# DAILY_LLM_SPEND_CAP_USD=
# PER_RUN_TOKEN_CEILING=
# PER_RUN_STEP_CEILING=
# RATE_LIMIT_PER_IP_PER_HOUR=
