# Cadenza reverse proxy + automatic TLS (CLAUDE.md §3, §13).
#
# CADENZA_DOMAIN drives the site address: set it to cadenza.devs-core.com in prod
# for automatic Let's Encrypt TLS; it defaults to localhost (Caddy serves a local
# self-signed cert) for `docker compose up` on a laptop.

{$CADENZA_DOMAIN:localhost} {
	encode zstd gzip

	# API gateway (REST + SSE). flush_interval -1 disables response buffering so
	# Server-Sent Events stream to the browser immediately. Caddy sets
	# X-Forwarded-For, which the gateway reads for per-IP rate limiting (§8.2).
	@api path /api/* /healthz
	handle @api {
		reverse_proxy api:8000 {
			flush_interval -1
		}
	}

	# Everything else → the Next.js frontend.
	handle {
		reverse_proxy web:3000
	}
}
